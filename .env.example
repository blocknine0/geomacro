# ---- Server-only secrets (never prefix with VITE_) ----
# Lovable AI Gateway — managed by Lovable; rotate via the platform.
LOVABLE_API_KEY=
# NewsAPI.org key — powers the public Live Feed (geopolitics / macro / rare-earth / crypto)
# and the Autonomous Oracle / Agent Arena live news context.
NEWSAPI_KEY=
# Groq API key — llama-3.3-70b-versatile classifies fetched articles into structured events.
GROQ_API_KEY=
# External Supabase project (separate from any Lovable Cloud project) used to persist
# classified Live Feed events into public.events. Leave unset to skip persistence.
APP_SUPABASE_URL=
APP_SUPABASE_ANON_KEY=

# ---- Public, build-time config (safe to expose) ----
# Force a specific Arc network. Leave unset for auto (mainnet when live,
# else testnet). Accepted values: mainnet | testnet
VITE_ARC_NETWORK=